








# imports (just run this cell)
import matplotlib.pyplot as plt
from astropy.table import Table


# reading in the text file (just run this cell)
filepath = 'PREM_EarthModel.txt'
table = Table.read(filepath, format='ascii')
table


# your plotting code goes here!

x = table["radius"]
y = table["density"]

plt.figure()
plt.scatter(x, y, label="radius and density")
plt.title("Earth's Radius vs. Density")
plt.xlabel("Radius")
plt.ylabel("Density")
plt.legend(loc="lower right")
plt.show()






